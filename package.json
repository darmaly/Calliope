{
  "name": "calliope",
  "version": "0.1.0",
  "private": true,
  "main": "app/out/main/index.js",
  "scripts": {
    "build:native": "cmake-js build",
    "rebuild:native": "cmake-js rebuild",
    "clean:native": "cmake-js clean",
    "dev": "cd app && electron-vite dev",
    "build:app": "cd app && electron-vite build",
    "build": "pnpm run build:native && pnpm run build:app",
    "start": "pnpm run build && electron app/out/main/index.js",
    "pack": "pnpm run build && electron-builder --dir",
    "test": "vitest run",
    "test:native": "vitest run test/native.test.ts",
    "test:app": "vitest run test/app.test.ts",
    "test:all": "vitest run"
  },
  "cmake-js": {
    "runtime": "electron",
    "runtimeVersion": "35.7.5"
  },
  "dependencies": {
    "@pixi/react": "^8.0.5",
    "lucide-react": "^1.7.0",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@swc/core": "^1.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "cmake-js": "8.0.0",
    "electron": "35.7.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "node-addon-api": "^8.7.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "electron",
      "esbuild"
    ]
  }
}